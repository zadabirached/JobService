# Copy this file to .env in the same folder as docker-compose.yml and fill in real values.
# .env is git-ignored — docker compose reads it automatically, so credentials never need to
# be typed on the command line or committed to docker-compose.yml.
#
#   cp .env.example .env

POSTGRES_DB=jobservice
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

GRAFANA_ADMIN_PASSWORD=admin
